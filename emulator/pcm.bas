10 POKE $9F3B,$80         : REM FIFO RESET
20 POKE $9F3B,$0F         : REM 8-BIT MONO, VOL 15
30 POKE $9F3C,0           : REM RATE 0 = HOLD
40 PRINT "BEFORE FILL:";PEEK($9F3B)
50 FOR I=1 TO 300
60 FOR J=1 TO 8:POKE $9F3D,$60:NEXT
70 FOR J=1 TO 8:POKE $9F3D,$A0:NEXT
80 NEXT
90 PRINT "AFTER FILL:";PEEK($9F3B)
100 POKE $9F3C,$10        : REM PLAY (6104 HZ RATE)
110 PRINT "PLAYING..."
120 FOR I=1 TO 4000:NEXT
130 PRINT "AFTER PLAY:";PEEK($9F3B)